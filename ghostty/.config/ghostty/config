# =========================
# Ghostty Configuration
# =========================

# ---------- General ----------
quit-after-last-window-closed = true
auto-update = download

# ---------- Appearance ----------
theme = dark:karl-dark,light:primary
window-theme = system
window-colorspace = display-p3

# ---------- Font ----------
font-family = Jetbrains Mono
font-size = 22

# ---------- Cursor & Mouse ----------
cursor-style = block_hollow
cursor-click-to-move = true
mouse-hide-while-typing = false

# ---------- Window Behavior ----------
window-subtitle = working-directory
window-save-state = always
confirm-close-surface = false
focus-follows-mouse = true

# Padding + cell-based resizing (helps reduce weird gaps with Neovim)
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0
window-padding-color = extend-always
# window-step-resize = true

# ---------- macOS Specific ----------
# macos-titlebar-style = tabs
macos-titlebar-style = hidden
macos-window-buttons = hidden
# macos-icon = retro



# ---------- Keybindings ----------
# Splits - Creation
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
# Splits - Navigation
# keybind = cmd+opt+left=goto_split:left
keybind = opt+h=goto_split:left
# keybind = cmd+opt+right=goto_split:right
keybind = opt+l=goto_split:right
keybind = cmd+opt+up=goto_split:top
keybind = cmd+opt+down=goto_split:bottom
keybind = cmd+shift+zero=equalize_splits
# Tab navigation (Safari-style)
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
# Font size / zoom
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+equal=increase_font_size:1
keybind = cmd+zero=reset_font_size

# Toggle background transparency (configured via background-opacity)
# NOTE: Ghostty 1.2.3 stable doesn't ship this action yet.
# Uncomment after upgrading to a build where `ghostty +list-actions` includes it.
# keybind = cmd+shift+o=toggle_background_opacity

background-opacity = 0.95
