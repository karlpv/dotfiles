# Sioyek preferences tuned to feel closer to zathura

# Keep modern key parsing
use_legacy_keybinds 0

# Skip network/version check on startup
check_for_updates_on_startup 0

# Startup and large-file performance
create_table_of_contents_if_not_exists 1

# flat_toc 1
collapsed_toc 1
rerender_overview 0
multiline_menus 1
super_fast_search 1
smooth_scroll_speed 3
smooth_scroll_drag 3000
should_load_tutorial_when_no_other_file 1
# Similar visual feel to your zathura recolor setup
dark_mode_background_color 0.0 0.0 0.0
dark_mode_contrast 0.8
 create_table_of_contents_if_not_exists 1

# Keep one-page reading flow and context-preserving paging
move_screen_ratio 0.5
