# Sioyek keybindings tuned for Zathura-like workflow

# Navigation / history
screen_down <C-d>
screen_up <C-u>
prev_state <C-o>
next_state <C-i>
# Table of contents (index)
goto_toc <tab>
# Keep portal features on explicit combos
goto_portal gp
edit_portal gP
toggle_presentation_mode d

# Zathura-like core actions
toggle_dark_mode i
reload r
rotate_clockwise R
print p

# Match your zoom muscle memory from zathura
zoom_out J
zoom_in K

next_page n
previous_page m
              
# Keep useful fit command
fit_to_page_width s
toggle_smooth_scroll_mode <C-s>
